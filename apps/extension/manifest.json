{
  "manifest_version": 3,
  "name": "Stashly",
  "description": "Save links and search your recall from the browser toolbar.",
  "version": "0.1.0",
  "permissions": ["storage", "tabs", "identity"],
  "host_permissions": [
    "https://stashly-api-66mp.onrender.com/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Stashly",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  }
}
